# Webhook server
CAC_BIND_ADDR=0.0.0.0:8080
CAC_WEBHOOK_SECRET=generate-a-long-random-secret
CAC_PUBLIC_URL=https://cac.example.com

# API tokens for commit status, PR comments, and fix-PR pushes
CAC_GITHUB_TOKEN=
CAC_CODEBERG_TOKEN=

# Audit ledger signing
CAC_LEDGER_SIGNING_KEY=generate-a-long-random-key

# Optional: auto-create fix PRs when violations are found
CAC_AUTO_FIX_PR=false

# Work directory for cloned PR checkouts
CAC_WORK_DIR=/tmp/cac-webhook
