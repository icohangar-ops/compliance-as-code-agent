{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    { "type": "TextBlock", "text": "Gate cleared — ${month} ${year}", "weight": "Bolder", "size": "Large", "color": "Good" },
    { "type": "TextBlock", "text": "${persona} · ${points} pts (gate = 25)" }
  ],
  "actions": [
    { "type": "Action.Submit", "title": "Share to BD-Ops", "data": { "verb": "share_celebration" } },
    { "type": "Action.Submit", "title": "Dismiss",         "data": { "verb": "dismiss" } }
  ]
}
