# Copy to .env, fill in. NEVER commit .env.
# Production: source from Vault (./scripts/render_env_from_vault.sh)

# --- Domain ---
BD_COACH_DOMAIN=example.com
ACME_EMAIL=admin@example.com
TIMEZONE=UTC

# --- Keycloak ---
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_LIBRECHAT_SECRET=

# --- Models (Ollama primary, Groq optional failover) ---
# Hostinger VPS (no GPU): set GROQ_API_KEY and use slim compose overlay.
LITELLM_MASTER_KEY=
GROQ_API_KEY=
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_CEO_MODEL=llama3.2:3b
OLLAMA_BD_MODEL=mistral:7b
# BD_COACH_SLIM=1          # pass to bootstrap.sh on 8 GB plans

# --- Baserow (pipeline + dashboard) ---
BASEROW_TOKEN=
BASEROW_TABLE_PIPELINE=
BASEROW_TABLE_ACTIVITY=
BASEROW_SECRET_KEY=

# --- Nextcloud (documents + CalDAV) ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=
NEXTCLOUD_USER=bd-coach
NEXTCLOUD_APP_PASSWORD=

# --- Mattermost webhooks ---
MM_HOOK_F1=
MM_HOOK_F3=
MM_HOOK_F4=
MM_HOOK_F7=
MM_HOOK_CEO_DIGEST=
MM_ADMIN_TOKEN=

# --- SMTP (F1/F5/F6 email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=bd-coach@example.com

# --- Infra secrets ---
PG_PASSWORD=
N8N_ENCRYPTION_KEY=
VAULT_ROOT_TOKEN=
MINIO_ROOT_PASSWORD=
OO_ADMIN_EMAIL=admin@example.com
OO_PASSWORD=
GRAFANA_PASSWORD=

# --- Deploy (CI only) ---
DEPLOY_HOST=
DEPLOY_USER=bdcoach
DEPLOY_SSH_KEY=
